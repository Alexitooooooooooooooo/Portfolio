---
import { technologies } from "../data/config";

interface Props {
  techStack: string[];
}

const { techStack } = Astro.props;
// Mapear los nombres a objetos con icono
const techStackWithIcons = techStack.map(name => technologies.find(t => t.name === name) || { name });
---

<section>
  <h2 class="text-3xl font-bold text-white flex items-center gap-3">
    Tecnologías
    <div class="h-px bg-zinc-800 flex-grow ml-4"></div>
  </h2>

  <div class="flex flex-wrap gap-3 pt-2 mt-6">
    {techStackWithIcons.map(tech => (
      <span class="flex items-center gap-2 px-4 py-1.5 bg-portfolio-panel border border-white/5 text-portfolio-accent text-sm font-mono rounded-lg hover:bg-portfolio-accent/10 transition-colors cursor-default">
        {tech.icon && <img src={tech.icon} alt={tech.name} class="w-5 h-5" loading="lazy" />}
        {tech.name}
      </span>
    ))}
  </div>
</section>
